alter table public.post_comments enable row level security;
create policy "Anyone reads comments" on public.post_comments for select using (true);
create policy "Auth users comment" on public.post_comments for insert with check (auth.uid() = user_id);
create policy "Own delete comment" on public.post_comments for delete using (auth.uid() = user_id);

