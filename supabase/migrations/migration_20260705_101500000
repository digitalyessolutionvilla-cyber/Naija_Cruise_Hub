-- 10) Admin RPC functions
create or replace function public.admin_get_dashboard_metrics()
returns jsonb
language plpgsql
security definer
as $$
declare
  v_today date := current_date;
  v_month_start date := date_trunc('month', now())::date;
  v_result jsonb;
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  select jsonb_build_object(
    'total_registered_users', (select count(*) from public.profiles),
    'active_users_today', (select count(distinct user_id) from public.daily_logins where login_date = v_today),
    'online_users', (select count(*) from public.profiles where is_online = true),
    'new_signups_today', (select count(*) from public.profiles where created_at::date = v_today),
    'new_signups_week', (select count(*) from public.profiles where created_at >= now() - interval '7 days'),
    'new_signups_month', (select count(*) from public.profiles where created_at::date >= v_month_start),
    'total_posts', (select count(*) from public.posts),
    'total_memes', (select count(*) from public.posts where type = 'meme'),
    'total_reels', (select count(*) from public.reels),
    'total_comments', (select count(*) from public.post_comments),
    'total_shares', (select count(*) from public.post_shares),
    'total_likes', (select count(*) from public.post_likes),
    'total_chat_messages', (select (select count(*) from public.room_messages) + (select count(*) from public.private_messages)),
    'active_chat_rooms', (select count(*) from public.chat_rooms where is_active = true and coalesce(is_removed, false) = false),
    'daily_revenue', (select coalesce(sum(amount), 0) from public.platform_revenue_events where status = 'completed' and created_at::date = v_today),
    'monthly_revenue', (select coalesce(sum(amount), 0) from public.platform_revenue_events where status = 'completed' and created_at::date >= v_month_start),
    'coins_in_circulation', (select coalesce(sum(coins), 0) from public.profiles),
    'wallet_balances', (select coalesce(sum(cash_balance), 0) from public.user_wallets),
    'pending_withdrawals', (select count(*) from public.withdrawal_requests where status = 'pending'),
    'approved_withdrawals', (select count(*) from public.withdrawal_requests where status in ('approved','paid')),
    'total_advertisements', (select count(*) from public.ad_campaigns),
    'active_advertisements', (select count(*) from public.ad_campaigns where is_active = true and is_paused = false),
    'reported_users', (select count(*) from public.content_reports where target_type = 'user' and status = 'pending'),
    'reported_posts', (select count(*) from public.content_reports where target_type in ('post','meme','reel') and status = 'pending'),
    'banned_users', (select count(*) from public.user_security_flags where is_banned = true)
  ) into v_result;

  return v_result;
end;
$$;

create or replace function public.admin_get_growth_charts(p_days integer default 30)
returns jsonb
language plpgsql
security definer
as $$
declare
  v_days integer := greatest(1, least(p_days, 365));
  v_result jsonb;
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  with date_series as (
    select generate_series(current_date - (v_days - 1), current_date, interval '1 day')::date as day
  ),
  signups as (
    select d.day, coalesce(count(p.id), 0) as value
    from date_series d
    left join public.profiles p on p.created_at::date = d.day
    group by d.day
    order by d.day
  ),
  traffic as (
    select d.day, coalesce(count(t.id), 0) as value
    from date_series d
    left join public.traffic_events t on t.created_at::date = d.day
    group by d.day
    order by d.day
  ),
  revenue as (
    select d.day, coalesce(sum(r.amount), 0) as value
    from date_series d
    left join public.platform_revenue_events r on r.created_at::date = d.day and r.status = 'completed'
    group by d.day
    order by d.day
  ),
  coins as (
    select d.day, coalesce(sum(w.cruise_coin_balance), 0) as value
    from date_series d
    left join public.user_wallets w on true
    group by d.day
    order by d.day
  ),
  ad_perf as (
    select c.id,
      c.title,
      count(*) filter (where e.event_type = 'impression')::int as impressions,
      count(*) filter (where e.event_type = 'click')::int as clicks
    from public.ad_campaigns c
    left join public.ad_events e on e.campaign_id = c.id and e.created_at >= now() - (v_days || ' days')::interval
    group by c.id, c.title
    order by clicks desc, impressions desc
    limit 10
  ),
  wallet_tx as (
    select d.day, coalesce(count(wt.id), 0) as value
    from date_series d
    left join public.wallet_transactions wt on wt.created_at::date = d.day
    group by d.day
    order by d.day
  ),
  hourly_active as (
    select h.hour,
      coalesce(count(distinct te.user_id), 0)::int as value
    from (
      select generate_series(0, 23) as hour
    ) h
    left join public.traffic_events te
      on date_part('hour', te.created_at) = h.hour
      and te.created_at >= now() - interval '1 day'
    group by h.hour
    order by h.hour
  )
  select jsonb_build_object(
    'user_growth', (select jsonb_agg(jsonb_build_object('date', day, 'value', value)) from signups),
    'daily_traffic', (select jsonb_agg(jsonb_build_object('date', day, 'value', value)) from traffic),
    'hourly_active_users', (select jsonb_agg(jsonb_build_object('hour', hour, 'value', value)) from hourly_active),
    'revenue_trends', (select jsonb_agg(jsonb_build_object('date', day, 'value', value)) from revenue),
    'coin_circulation', (select jsonb_agg(jsonb_build_object('date', day, 'value', value)) from coins),
    'wallet_transactions', (select jsonb_agg(jsonb_build_object('date', day, 'value', value)) from wallet_tx),
    'advertisement_performance', (
      select coalesce(jsonb_agg(jsonb_build_object(
        'campaign_id', id,
        'title', title,
        'impressions', impressions,
        'clicks', clicks,
        'ctr', case when impressions = 0 then 0 else round((clicks::numeric / impressions::numeric) * 100, 2) end
      )), '[]'::jsonb)
      from ad_perf
    )
  ) into v_result;

  return v_result;
end;
$$;

create or replace function public.admin_get_users(
  p_query text default '',
  p_limit integer default 20,
  p_offset integer default 0
)
returns table(
  user_id uuid,
  username text,
  level text,
  xp integer,
  coins integer,
  created_at timestamptz,
  is_online boolean,
  is_verified boolean,
  is_suspended boolean,
  is_banned boolean,
  role text,
  cash_balance numeric,
  coin_balance numeric
)
language sql
security definer
as $$
  select
    p.id as user_id,
    p.username,
    p.level,
    coalesce(p.xp, 0) as xp,
    coalesce(p.coins, 0) as coins,
    p.created_at,
    coalesce(p.is_online, false) as is_online,
    coalesce(usf.is_verified, false) as is_verified,
    coalesce(usf.is_suspended, false) as is_suspended,
    coalesce(usf.is_banned, false) as is_banned,
    au.role,
    coalesce(w.cash_balance, 0) as cash_balance,
    coalesce(w.cruise_coin_balance, 0) as coin_balance
  from public.profiles p
  left join public.user_security_flags usf on usf.user_id = p.id
  left join public.admin_users au on au.user_id = p.id and au.is_active = true
  left join public.user_wallets w on w.user_id = p.id
  where public.is_admin_user(auth.uid())
    and (
      p_query = ''
      or p.username ilike '%' || p_query || '%'
      or p.id::text ilike '%' || p_query || '%'
    )
  order by p.created_at desc
  limit greatest(1, least(p_limit, 200))
  offset greatest(0, p_offset);
$$;

create or replace function public.admin_set_user_state(
  p_user_id uuid,
  p_action text,
  p_reason text default null,
  p_suspended_until timestamptz default null
)
returns jsonb
language plpgsql
security definer
as $$
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  insert into public.user_security_flags(user_id)
  values (p_user_id)
  on conflict (user_id) do nothing;

  if p_action = 'verify' then
    update public.user_security_flags
      set is_verified = true,
          updated_at = now()
      where user_id = p_user_id;
  elsif p_action = 'suspend' then
    update public.user_security_flags
      set is_suspended = true,
          suspension_reason = p_reason,
          suspended_until = p_suspended_until,
          updated_at = now()
      where user_id = p_user_id;
  elsif p_action = 'ban' then
    update public.user_security_flags
      set is_banned = true,
          banned_reason = p_reason,
          is_suspended = true,
          updated_at = now()
      where user_id = p_user_id;
  elsif p_action = 'reactivate' then
    update public.user_security_flags
      set is_suspended = false,
          is_banned = false,
          suspension_reason = null,
          banned_reason = null,
          suspended_until = null,
          updated_at = now()
      where user_id = p_user_id;
  else
    raise exception 'Unsupported action';
  end if;

  perform public.log_admin_action(
    'user_state_' || p_action,
    'user',
    p_user_id::text,
    jsonb_build_object('reason', p_reason, 'suspended_until', p_suspended_until)
  );

  return jsonb_build_object('ok', true);
end;
$$;

