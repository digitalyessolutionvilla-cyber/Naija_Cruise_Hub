create or replace function public.admin_moderate_content(
  p_report_id uuid,
  p_action text,
  p_notes text default null
)
returns jsonb
language plpgsql
security definer
as $$
declare
  v_report public.content_reports%rowtype;
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  select * into v_report
  from public.content_reports
  where id = p_report_id
  for update;

  if not found then
    raise exception 'Report not found';
  end if;

  if p_action = 'remove' then
    if v_report.target_type in ('post', 'meme') then
      update public.posts set is_removed = true where id::text = v_report.target_id;
    elsif v_report.target_type = 'comment' then
      update public.post_comments set is_removed = true where id::text = v_report.target_id;
    elsif v_report.target_type = 'reel' then
      update public.reels set is_removed = true where id::text = v_report.target_id;
    elsif v_report.target_type = 'room_message' then
      update public.room_messages set is_removed = true where id::text = v_report.target_id;
    elsif v_report.target_type = 'chat_room' then
      update public.chat_rooms set is_removed = true where id::text = v_report.target_id;
    end if;
  elsif p_action = 'restore' then
    if v_report.target_type in ('post', 'meme') then
      update public.posts set is_removed = false where id::text = v_report.target_id;
    elsif v_report.target_type = 'comment' then
      update public.post_comments set is_removed = false where id::text = v_report.target_id;
    elsif v_report.target_type = 'reel' then
      update public.reels set is_removed = false where id::text = v_report.target_id;
    elsif v_report.target_type = 'room_message' then
      update public.room_messages set is_removed = false where id::text = v_report.target_id;
    elsif v_report.target_type = 'chat_room' then
      update public.chat_rooms set is_removed = false where id::text = v_report.target_id;
    end if;
  elsif p_action = 'delete_permanent' then
    if v_report.target_type in ('post', 'meme') then
      delete from public.posts where id::text = v_report.target_id;
    elsif v_report.target_type = 'comment' then
      delete from public.post_comments where id::text = v_report.target_id;
    elsif v_report.target_type = 'reel' then
      delete from public.reels where id::text = v_report.target_id;
    elsif v_report.target_type = 'room_message' then
      delete from public.room_messages where id::text = v_report.target_id;
    end if;
  elsif p_action = 'warn' then
    null;
  else
    raise exception 'Unsupported moderation action';
  end if;

  update public.content_reports
  set status = 'resolved',
      reviewed_by = auth.uid(),
      review_notes = p_notes,
      reviewed_at = now()
  where id = p_report_id;

  insert into public.moderation_actions(target_type, target_id, action, taken_by, notes)
  values (v_report.target_type, v_report.target_id, p_action, auth.uid(), p_notes);

  perform public.log_admin_action(
    'moderate_' || p_action,
    v_report.target_type,
    v_report.target_id,
    jsonb_build_object('report_id', p_report_id, 'notes', p_notes)
  );

  return jsonb_build_object('ok', true);
end;
$$;

create or replace function public.admin_upsert_ad_campaign(
  p_id uuid,
  p_title text,
  p_media_url text,
  p_media_type text,
  p_placement text,
  p_destination_url text,
  p_start_at timestamptz,
  p_end_at timestamptz,
  p_display_frequency integer,
  p_is_active boolean,
  p_is_paused boolean
)
returns uuid
language plpgsql
security definer
as $$
declare
  v_id uuid;
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  if p_id is null then
    insert into public.ad_campaigns(
      title, media_url, media_type, placement, destination_url,
      start_at, end_at, display_frequency, is_active, is_paused, created_by
    ) values (
      p_title, p_media_url, p_media_type, p_placement, p_destination_url,
      p_start_at, p_end_at, coalesce(p_display_frequency, 1),
      coalesce(p_is_active, true), coalesce(p_is_paused, false), auth.uid()
    ) returning id into v_id;
  else
    update public.ad_campaigns
    set title = p_title,
        media_url = p_media_url,
        media_type = p_media_type,
        placement = p_placement,
        destination_url = p_destination_url,
        start_at = p_start_at,
        end_at = p_end_at,
        display_frequency = coalesce(p_display_frequency, display_frequency),
        is_active = coalesce(p_is_active, is_active),
        is_paused = coalesce(p_is_paused, is_paused)
    where id = p_id;
    v_id := p_id;
  end if;

  perform public.log_admin_action('upsert_ad_campaign', 'ad_campaign', v_id::text, jsonb_build_object('title', p_title));
  return v_id;
end;
$$;

create or replace function public.admin_get_ads()
returns table(
  id uuid,
  title text,
  media_url text,
  media_type text,
  placement text,
  destination_url text,
  start_at timestamptz,
  end_at timestamptz,
  display_frequency integer,
  is_active boolean,
  is_paused boolean,
  impressions bigint,
  clicks bigint,
  ctr numeric
)
language sql
security definer
as $$
  select
    c.id,
    c.title,
    c.media_url,
    c.media_type,
    c.placement,
    c.destination_url,
    c.start_at,
    c.end_at,
    c.display_frequency,
    c.is_active,
    c.is_paused,
    count(e.id) filter (where e.event_type = 'impression') as impressions,
    count(e.id) filter (where e.event_type = 'click') as clicks,
    case
      when count(e.id) filter (where e.event_type = 'impression') = 0 then 0
      else round(((count(e.id) filter (where e.event_type = 'click'))::numeric / (count(e.id) filter (where e.event_type = 'impression'))::numeric) * 100, 2)
    end as ctr
  from public.ad_campaigns c
  left join public.ad_events e on e.campaign_id = c.id
  where public.is_admin_user(auth.uid())
  group by c.id
  order by c.created_at desc;
$$;

