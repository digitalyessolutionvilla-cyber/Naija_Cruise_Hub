    wt.created_at
  from public.wallet_transactions wt
  join public.profiles p on p.id = wt.user_id
  where public.is_admin_user(auth.uid())
    and (p_user_id is null or wt.user_id = p_user_id)
  order by wt.created_at desc
  limit greatest(1, least(p_limit, 500))
  offset greatest(0, p_offset);
$$;

create or replace function public.admin_get_revenue_summary()
returns jsonb
language plpgsql
security definer
as $$
declare
  v_result jsonb;
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  select jsonb_build_object(
    'daily_revenue', coalesce((select sum(amount) from public.platform_revenue_events where status = 'completed' and created_at::date = current_date), 0),
    'weekly_revenue', coalesce((select sum(amount) from public.platform_revenue_events where status = 'completed' and created_at >= now() - interval '7 days'), 0),
    'monthly_revenue', coalesce((select sum(amount) from public.platform_revenue_events where status = 'completed' and created_at >= date_trunc('month', now())), 0),
    'annual_revenue', coalesce((select sum(amount) from public.platform_revenue_events where status = 'completed' and created_at >= date_trunc('year', now())), 0)
  ) into v_result;

  return v_result;
end;
$$;

create or replace function public.admin_get_my_role()
returns jsonb
language plpgsql
security definer
as $$
begin
  if not public.is_admin_user(auth.uid()) then
    return jsonb_build_object('is_admin', false, 'role', null);
  end if;

  return jsonb_build_object(
    'is_admin', true,
    'role', public.current_admin_role(auth.uid())
  );
end;
$$;
