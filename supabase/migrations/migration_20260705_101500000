create or replace function public.admin_review_withdrawal(
  p_withdrawal_id uuid,
  p_decision text,
  p_reason text default null
)
returns jsonb
language plpgsql
security definer
as $$
declare
  v_req public.withdrawal_requests%rowtype;
  v_ref text;
begin
  if not public.is_admin_user(auth.uid()) then
    raise exception 'Unauthorized';
  end if;

  select * into v_req
  from public.withdrawal_requests
  where id = p_withdrawal_id
  for update;

  if not found then
    raise exception 'Withdrawal not found';
  end if;

  if v_req.status <> 'pending' then
    raise exception 'Only pending withdrawals can be reviewed';
  end if;

  if p_decision = 'approve' then
    update public.withdrawal_requests
    set status = 'approved',
        reviewed_by = auth.uid(),
        review_notes = p_reason,
        reviewed_at = now(),
        updated_at = now()
    where id = p_withdrawal_id;

    update public.user_wallets
    set pending_balance = pending_balance - v_req.amount,
        total_withdrawals = total_withdrawals + v_req.amount,
        updated_at = now()
    where user_id = v_req.user_id;

    update public.withdrawal_requests
    set status = 'paid', updated_at = now()
    where id = p_withdrawal_id;

    v_ref := 'WPD-' || to_char(now(), 'YYYYMMDDHH24MISSMS') || '-' || substr(replace(gen_random_uuid()::text, '-', ''), 1, 8);

    insert into public.wallet_transactions(
      user_id,
      transaction_type,
      asset_type,
      amount,
      status,
      description,
      reference_number,
      created_by,
      metadata
    ) values (
      v_req.user_id,
      'withdrawal',
      'cash',
      -v_req.amount,
      'completed',
      'Withdrawal paid by admin',
      v_ref,
      auth.uid(),
      jsonb_build_object('withdrawal_id', p_withdrawal_id)
    );
  elsif p_decision = 'reject' then
    update public.withdrawal_requests
    set status = 'rejected',
        reviewed_by = auth.uid(),
        review_notes = p_reason,
        reviewed_at = now(),
        updated_at = now()
    where id = p_withdrawal_id;

    update public.user_wallets
    set pending_balance = pending_balance - v_req.amount,
        cash_balance = cash_balance + v_req.amount,
        updated_at = now()
    where user_id = v_req.user_id;
  else
    raise exception 'Invalid decision';
  end if;

  perform public.log_admin_action(
    'review_withdrawal_' || p_decision,
    'withdrawal',
    p_withdrawal_id::text,
    jsonb_build_object('reason', p_reason)
  );

  return jsonb_build_object('ok', true);
end;
$$;

