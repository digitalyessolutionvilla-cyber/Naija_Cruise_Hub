  insert into public.admin_users(user_id, role, permissions, is_active)
  values (p_user_id, p_role, '{}'::jsonb, true)
  on conflict (user_id)
  do update set role = excluded.role, is_active = true;

  perform public.log_admin_action('assign_role', 'user', p_user_id::text, jsonb_build_object('role', p_role));
  return jsonb_build_object('ok', true);
end;
$$;

