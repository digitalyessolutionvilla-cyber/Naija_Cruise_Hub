  for select using (auth.uid() = user_id or public.is_admin_user(auth.uid()));

create or replace function public.reward_task_scope_key(p_reset_period text)
returns text
language sql
stable
as $$
  select case
    when p_reset_period = 'daily' then to_char(current_date, 'YYYY-MM-DD')
    when p_reset_period = 'weekly' then to_char(date_trunc('week', now()), 'IYYY-IW')
    else 'once'
  end;
$$;

create or replace function public.reward_task_progress_count(p_task_key text)
returns integer
language plpgsql
security definer
stable
as $$
declare
  v_count integer := 0;
begin
  if auth.uid() is null then
    return 0;
  end if;

  case p_task_key
    when 'daily_login' then
      select count(*)::int into v_count
      from public.daily_logins
      where user_id = auth.uid()
        and login_date = current_date;
    when 'create_engaging_posts' then
      select count(*)::int into v_count
      from public.posts
      where user_id = auth.uid();
    when 'upload_memes' then
      select count(*)::int into v_count
      from public.posts
      where user_id = auth.uid()
        and type = 'meme';
    when 'upload_reels' then
      select count(*)::int into v_count
      from public.posts
      where user_id = auth.uid()
        and type = 'reel';
    when 'comment_on_posts' then
      select count(*)::int into v_count
      from public.post_comments
      where user_id = auth.uid();
    when 'like_and_share_posts' then
      select (
        coalesce((select count(*) from public.post_likes where user_id = auth.uid()), 0) +
        coalesce((select count(*) from public.post_shares where user_id = auth.uid()), 0)
      )::int into v_count;
    when 'join_chat_rooms' then
      select count(*)::int into v_count
      from public.room_members
      where user_id = auth.uid();
    when 'invite_friends' then
      select count(*)::int into v_count
      from public.friendships
      where requester_id = auth.uid();
    when 'complete_profile' then
      select case when exists (
        select 1 from public.profiles p
        where p.id = auth.uid()
          and coalesce(p.avatar_id, '') <> ''
          and coalesce(p.bio, '') <> ''
          and coalesce(p.gender, '') <> ''
          and coalesce(p.state, '') <> ''
          and coalesce(array_length(p.interests, 1), 0) > 0
      ) then 1 else 0 end into v_count;
    when 'community_events' then
      select count(*)::int into v_count
      from public.ad_events
      where user_id = auth.uid()
        and event_type in ('community_event', 'event_checkin', 'event_attend');
    when 'rewarded_ads' then
      select count(*)::int into v_count
      from public.ad_events
      where user_id = auth.uid()
        and event_type in ('rewarded_ad', 'rewarded_impression', 'rewarded_click');
    when 'daily_challenge' then
      select count(*)::int into v_count
      from public.user_reward_claims
      where user_id = auth.uid()
        and claimed_at::date = current_date
        and task_key not in ('daily_challenge', 'weekly_challenge');
    when 'weekly_challenge' then
      select count(*)::int into v_count
      from public.user_reward_claims
      where user_id = auth.uid()
        and claimed_at >= date_trunc('week', now())
        and task_key not in ('daily_challenge', 'weekly_challenge');
    when 'sponsored_campaigns' then
      select count(*)::int into v_count
      from public.ad_events
      where user_id = auth.uid()
        and event_type in ('campaign_join', 'campaign_click', 'campaign_view');
    else
      v_count := 0;
  end case;

  return coalesce(v_count, 0);
end;
$$;

create or replace function public.get_reward_tasks()
returns table (
  task_key text,
  title text,
  description text,
  category text,
  reward_coins numeric,
  target_count integer,
  current_count integer,
  claimable boolean,
  claimed boolean,
  reset_period text,
  time_remaining_seconds integer,
  scope_key text
)
language plpgsql
security definer
stable
as $$
declare
  v_task record;
  v_current integer;
  v_scope text;
  v_claimed boolean;
  v_time_remaining integer;
begin
  if auth.uid() is null then
    raise exception 'Unauthorized';
  end if;

  for v_task in
    select * from public.reward_task_definitions where is_active = true order by sort_order asc, title asc
  loop
    v_current := public.reward_task_progress_count(v_task.task_key);
    v_scope := public.reward_task_scope_key(v_task.reset_period);

    select exists (
      select 1 from public.user_reward_claims c
      where c.user_id = auth.uid()
        and c.task_key = v_task.task_key
        and c.scope_key = v_scope
    ) into v_claimed;

    v_time_remaining := null;
    if v_task.reset_period = 'daily' then
      v_time_remaining := extract(epoch from (date_trunc('day', now()) + interval '1 day' - now()))::int;
    elsif v_task.reset_period = 'weekly' then
      v_time_remaining := extract(epoch from (date_trunc('week', now()) + interval '1 week' - now()))::int;
    end if;

    task_key := v_task.task_key;
    title := v_task.title;
    description := v_task.description;
    category := v_task.category;
    reward_coins := v_task.reward_coins;
    target_count := v_task.target_count;
    current_count := least(v_current, v_task.target_count);
    claimable := v_current >= v_task.target_count and not v_claimed;
    claimed := v_claimed;
    reset_period := v_task.reset_period;
    time_remaining_seconds := v_time_remaining;
    scope_key := v_scope;
    return next;
  end loop;
end;
$$;

create or replace function public.claim_reward_task(p_task_key text)
returns jsonb
language plpgsql
security definer
as $$
declare
  v_task public.reward_task_definitions%rowtype;
  v_current integer;
  v_scope text;
  v_claimed boolean;
  v_ref text;
begin
  if auth.uid() is null then
    raise exception 'Unauthorized';
  end if;

  select * into v_task
  from public.reward_task_definitions
  where task_key = p_task_key
    and is_active = true;

  if not found then
    raise exception 'Task not found';
  end if;

  v_current := public.reward_task_progress_count(p_task_key);
  v_scope := public.reward_task_scope_key(v_task.reset_period);

  select exists (
    select 1 from public.user_reward_claims c
    where c.user_id = auth.uid()
      and c.task_key = p_task_key
      and c.scope_key = v_scope
  ) into v_claimed;

  if v_claimed then
    return jsonb_build_object('ok', true, 'already_claimed', true);
  end if;

  if v_current < v_task.target_count then
    raise exception 'Task is not completed yet';
  end if;

  insert into public.user_reward_claims(user_id, task_key, scope_key, reward_coins, metadata)
  values (auth.uid(), p_task_key, v_scope, v_task.reward_coins, coalesce(v_task.metadata, '{}'::jsonb));

  insert into public.user_wallets(user_id, cruise_coin_balance, updated_at)
  values (auth.uid(), 0, now())
  on conflict (user_id) do nothing;

  update public.profiles
  set coins = coalesce(coins, 0) + v_task.reward_coins
  where id = auth.uid();

  update public.user_wallets
  set cruise_coin_balance = coalesce(cruise_coin_balance, 0) + v_task.reward_coins,
      updated_at = now()
  where user_id = auth.uid();

  v_ref := 'TASK-' || to_char(now(), 'YYYYMMDDHH24MISSMS') || '-' || substr(replace(gen_random_uuid()::text, '-', ''), 1, 8);

  insert into public.wallet_transactions(
    user_id,
    transaction_type,
    asset_type,
    amount,
    status,
    description,
    reference_number,
    created_by,
    metadata
  ) values (
    auth.uid(),
    'reward',
    'coin',
    v_task.reward_coins,
    'completed',
    v_task.title,
    v_ref,
    auth.uid(),
    jsonb_build_object('source', 'task_reward', 'task_key', p_task_key)
  );

  return jsonb_build_object(
    'ok', true,
    'task_key', p_task_key,
    'reference_number', v_ref,
    'reward_coins', v_task.reward_coins
  );
end;
$$;
